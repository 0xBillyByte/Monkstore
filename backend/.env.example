# Copy this file to .env and fill in your values

# PostgreSQL connection string (also accepts lowercase: database_url)
DATABASE_URL=postgres://DB_USER:DB_PASSWORD@10.10.3.10:5432/monkeymint

# Port the backend listens on (default: 3000)
PORT=3000

# Allowed CORS origin for the frontend (use * for development)
FRONTEND_ORIGIN=*

# Secret used for JWT signing and password hashing – change in production!
JWT_SECRET=changeme_use_a_long_random_string_in_production
